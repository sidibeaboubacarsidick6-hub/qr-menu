# Django
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# URL publique du site (SANS slash final). Utilisée pour générer les QR codes.
# En production, mettez la vraie URL, ex: https://menu.mon-restaurant.com
SITE_URL=http://localhost:8000

# Domaines de confiance pour le CSRF derrière HTTPS (liste séparée par des virgules)
# ex: https://menu.mon-restaurant.com
CSRF_TRUSTED_ORIGINS=

# Redirection HTTPS automatique (à activer en production si vous avez un certificat)
SECURE_SSL_REDIRECT=False

# Base de données PostgreSQL
DB_NAME=qrmenu
DB_USER=qrmenu_user
DB_PASSWORD=votre-mot-de-passe
DB_HOST=localhost
DB_PORT=5432

# Langue
LANGUAGE_CODE=fr
TIME_ZONE=Europe/Paris

# Super Admin
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@qrmenu.com
DJANGO_SUPERUSER_PASSWORD=changez-moi
